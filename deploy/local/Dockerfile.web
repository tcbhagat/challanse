FROM node:22.17.0-bookworm-slim@sha256:b04ce4ae4e95b522112c2e5c52f781471a5cbc3b594527bcddedee9bc48c03a0

WORKDIR /app
COPY package.json package-lock.json ./
COPY apps ./apps
COPY packages ./packages
RUN npm ci && npm run build --workspace @challanse/contracts --if-present && npm run build --workspace @challanse/reviewer

ENV HOME=/tmp XDG_CONFIG_HOME=/tmp
USER node
CMD ["node", "--version"]
