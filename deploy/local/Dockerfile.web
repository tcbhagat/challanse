FROM node:24.8.0-bookworm-slim@sha256:cadbfafeb6baf87eaaffa40b3640209c4b7fd38cebde65059d15bc39cd636b85

WORKDIR /app
COPY package.json package-lock.json ./
COPY apps ./apps
COPY packages ./packages
RUN npm ci && npm run build --workspace @challanse/contracts --if-present && npm run build --workspace @challanse/reviewer

ENV HOME=/tmp XDG_CONFIG_HOME=/tmp
USER node
CMD ["node", "--version"]
